#!/usr/bin/env bash

# ***This script was made by Clay Gomera (Drake)***
#  - Description: A simple power menu rofi script
#  - Dependencies: rofi, power-profiles-daemon

## OPTIONS ##
option1="пАЮ Reboot"
option2="пАС Power off"
option3="п¶± Suspend"
option4="пДЊ Lock"
option5="пАН Cancel"

## OPTIONS ARRAY ##
options="$option1\n$option2\n$option3\n$option4\n$option5"
## MAIN ACTION COMMAND ##
action=$(echo -e "$options" | rofi -dmenu -b -l 5 -i -p "пАС ")
case "$action" in
    $option1*)
        loginctl reboot;;
    $option2*)
        loginctl poweroff;;
    $option3*)
        betterlockscreen --suspend blur;;
    $option4*)
        betterlockscreen -l  blur;;
    $option5*)
        exit 0
esac
